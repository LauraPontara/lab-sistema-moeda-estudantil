@startuml UC09-GerenciarEmpresa
title Sistema de Moeda Estudantil - UC09 - Gerenciar Empresa

actor "Admin" as ADM
actor "Empresa\nParceira" as E
participant "Sistema de\nCadastro" as FC
participant "Módulo do\nAdmin" as PA
participant "Sistema de\nEmpresas" as SE
database "Banco de\nDados" as BD

== 1. Cadastro da Empresa Parceira ==

E -> FC: 1.1 cadastroEmpresa()
activate FC
FC --> E: 1.2 exibirFormulario(campos)
deactivate FC

E -> FC: 1.3 preencherFormulario(nome, email, senha, cnpj, descricao, logoUrl)
activate FC

alt Campos obrigatórios não preenchidos
    FC --> E: 1.4 exibirErro("Preencha todos os campos obrigatórios")

else CNPJ em formato inválido
    FC --> E: 1.5 exibirErroCampo("cnpj", "Formato de CNPJ inválido")

else Dados válidos
    FC --> E: 1.6 exibirCarregando()
    deactivate FC
end

FC -> SE: 1.7 cadastrarEmpresa(dadosEmpresa)
activate SE
SE -> BD: 1.8 verificarEmailDisponivel(email)
activate BD
BD --> SE: 1.9 resultado
deactivate BD

alt Email já cadastrado
    SE --> FC: 1.10 erroEmailJaEmUso(email)
    activate FC
    FC --> E: 1.11 exibirErro("Este email já está em uso")
    deactivate FC

else Email disponível
    SE -> SE: 1.12 hashSenha(senha)
    SE -> BD: 1.13 criarEmpresa(dadosEmpresa)
    activate BD
    BD --> SE: 1.14 empresaCriada
    deactivate BD
    SE --> FC: 1.15 empresaCriada
    deactivate SE
    activate FC
    FC --> E: 1.16 redirecionarPara("/entrar")
    deactivate FC
end

== 2. Listagem de Empresas (Admin) ==

ADM -> PA: 2.1 acessarListaEmpresas()
activate PA
PA -> SE: 2.2 listarTodasEmpresas()
activate SE
SE -> BD: 2.3 buscarTodasEmpresas()
activate BD
BD --> SE: 2.4 listaEmpresas
deactivate BD
SE --> PA: 2.5 listaEmpresas
deactivate SE
PA --> ADM: 2.6 exibirTabelaEmpresas(listaEmpresas)
deactivate PA

== 3. Edição de Empresa (Admin) ==

E -> SE: 3.1 selecionarEditarEmpresa(empresaId)
activate SE
SE -> BD: 3.3 buscarEmpresa(empresaId)
activate BD
BD --> SE: 3.4 dadosEmpresa
deactivate BD
SE --> E: 3.6 exibirFormularioEdicao(dadosEmpresa)
deactivate SE

E -> SE: 3.7 submeterAlteracoes(empresaId, camposAtualizados)
activate SE
SE -> BD: 3.8 atualizarEmpresa(empresaId, camposAtualizados)
activate BD
BD --> SE: 3.9 empresaAtualizada
deactivate BD
SE --> E: 3.10 exibirSucesso("Empresa atualizada com sucesso")
deactivate SE

== 4. Remoção de Empresa (Admin) ==

ADM -> PA: 4.1 removerEmpresa(empresaId)
activate PA
PA -> SE: 4.2 excluirEmpresa(empresaId)
activate SE
SE -> BD: 4.3 deletarEmpresa(empresaId)
activate BD
BD --> SE: 4.4 confirmacao
deactivate BD
SE --> PA: 4.5 confirmacao
deactivate SE
PA --> ADM: 4.6 exibirSucesso("Empresa removida com sucesso")
deactivate PA

@enduml
