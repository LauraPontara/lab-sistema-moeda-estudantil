PORT=3001
DATABASE_URL="postgresql://postgres:senha@host:6543/postgres"
JWT_SECRET="troque-esta-chave"
JWT_EXPIRES_IN="1d"
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# Email (Brevo — API HTTP, porta 443; SMTP é bloqueado no Render free)
# API key gerada em Brevo > SMTP & API > aba "API Keys"
BREVO_API_KEY=xkeysib-xxxxxxxx
# Remetente verificado em Brevo > Remetentes, domínio, IPs
BREVO_SENDER_EMAIL=seuemail@gmail.com
BREVO_SENDER_NAME=Sistema de Moedas

# Reset password JWT (secret separado do JWT principal)
RESET_PASSWORD_SECRET=um_secret_bem_diferente_do_jwt_principal

# URL do frontend (para montar o link no email)
FRONTEND_URL=http://localhost:3000

# Supabase Queue (PGMQ)
SUPABASE_QUEUE_NAME=coin_transfer_events
SUPABASE_QUEUE_NAME_REDEMPTIONS=advantage_redemption_events

# WhatsApp (WAHA — https://waha.devlike.pro)
# URL base da instância WAHA (ex: http://localhost:3000)
WAHA_BASE_URL=http://localhost:3000
# Nome da sessão configurada no WAHA (padrão: default)
WAHA_SESSION=default
# API key do WAHA (deixe vazio se não tiver autenticação habilitada)
WAHA_API_KEY=
